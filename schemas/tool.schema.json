{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skill-marketplace-template/schemas/tool.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "title",
    "description",
    "inputSchema"
  ],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-zA-Z][a-zA-Z0-9_]*$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "inputSchema": {
      "type": "object"
    },
    "outputSchema": {
      "type": "object"
    }
  }
}
