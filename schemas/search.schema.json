{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skill-marketplace-template/schemas/search.schema.json",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "id",
      "category",
      "tokens",
      "text"
    ],
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      },
      "category": {
        "type": "string",
        "minLength": 1
      },
      "tokens": {
        "type": "array",
        "minItems": 1,
        "uniqueItems": true,
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "text": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
