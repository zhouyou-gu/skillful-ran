{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skill-marketplace-template/schemas/registry.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "marketplace",
    "skills"
  ],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "marketplace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "description",
        "url",
        "theme",
        "categories"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "author": {
          "type": ["string", "null"]
        },
        "license": {
          "type": ["string", "null"]
        },
        "url": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://"
        },
        "theme": {
          "type": "string"
        },
        "categories": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "description",
          "category",
          "tags",
          "difficulty",
          "repo",
          "path",
          "install",
          "agent",
          "tool"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "category": {
            "type": "string",
            "minLength": 1
          },
          "tags": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string"
            }
          },
          "difficulty": {
            "type": "string",
            "enum": [
              "beginner",
              "intermediate",
              "advanced"
            ]
          },
          "repo": {
            "type": "string",
            "format": "uri",
            "pattern": "^https://"
          },
          "path": {
            "type": "string",
            "pattern": "^skills/[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "install": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "pip": {
                "type": "string",
                "minLength": 1
              },
              "npm": {
                "type": "string",
                "minLength": 1
              }
            },
            "anyOf": [
              {
                "required": [
                  "pip"
                ]
              },
              {
                "required": [
                  "npm"
                ]
              }
            ]
          },
          "agent": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "protocol",
              "tool_schema"
            ],
            "properties": {
              "protocol": {
                "type": "string",
                "const": "mcp"
              },
              "tool_schema": {
                "type": "string",
                "pattern": "^skills/[a-z0-9]+(?:-[a-z0-9]+)*/.+$"
              }
            }
          },
          "tool": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "title",
              "description"
            ],
            "properties": {
              "name": {
                "type": "string",
                "pattern": "^[a-zA-Z][a-zA-Z0-9_]*$"
              },
              "title": {
                "type": "string",
                "minLength": 1
              },
              "description": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    }
  }
}
