{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skill-marketplace-template/schemas/config.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "title",
    "description",
    "theme",
    "categories"
  ],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "author": {
      "type": "string"
    },
    "license": {
      "type": "string"
    },
    "url": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://"
    },
    "theme": {
      "type": "string",
      "enum": [
        "light",
        "dark"
      ]
    },
    "categories": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      }
    }
  }
}
