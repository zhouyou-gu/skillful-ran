{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skill-marketplace-template/schemas/skill.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "description",
    "category",
    "tags",
    "difficulty",
    "repo",
    "install",
    "agent"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "type": "string",
      "minLength": 1
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      }
    },
    "difficulty": {
      "type": "string",
      "enum": [
        "beginner",
        "intermediate",
        "advanced"
      ]
    },
    "repo": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://"
    },
    "install": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pip": {
          "type": "string",
          "minLength": 1
        },
        "npm": {
          "type": "string",
          "minLength": 1
        }
      },
      "anyOf": [
        {
          "required": [
            "pip"
          ]
        },
        {
          "required": [
            "npm"
          ]
        }
      ]
    },
    "agent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocol",
        "tool_schema"
      ],
      "properties": {
        "protocol": {
          "type": "string",
          "const": "mcp"
        },
        "tool_schema": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
