{
  "name": "ocudu_host_audit",
  "title": "OCUDU Host Audit",
  "description": "Collect a Linux readiness report for OCUDU and srsRAN build work without changing the system.",
  "inputSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "workspace": {
        "type": "string",
        "default": ".local/ocudu"
      },
      "profile": {
        "type": "string",
        "enum": ["ubuntu-24.04-gaming-pc", "portable-linux"],
        "default": "ubuntu-24.04-gaming-pc"
      },
      "check_network": {
        "type": "boolean",
        "default": true
      },
      "check_packages": {
        "type": "boolean",
        "default": true
      },
      "strict": {
        "type": "boolean",
        "default": false
      }
    },
    "required": ["workspace"]
  },
  "outputSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "passed": { "type": "boolean" },
      "summary": { "type": "string" },
      "warnings": {
        "type": "array",
        "items": { "type": "string" }
      },
      "artifacts": {
        "type": "array",
        "items": { "type": "string" }
      },
      "next_steps": {
        "type": "array",
        "items": { "type": "string" }
      },
      "hardware": { "type": "object" },
      "missing": {
        "type": "array",
        "items": { "type": "string" }
      },
      "checks": {
        "type": "array",
        "items": { "type": "object" }
      }
    },
    "required": [
      "passed",
      "summary",
      "warnings",
      "artifacts",
      "next_steps",
      "hardware",
      "missing",
      "checks"
    ]
  }
}
