{
  "name": "ocudu_build_install",
  "title": "OCUDU Build Install",
  "description": "Plan or execute the baseline source, build, test, and install flow for OCUDU and srsRAN inside the local workspace.",
  "inputSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "workspace": {
        "type": "string",
        "default": ".local/ocudu"
      },
      "source_ref": {
        "type": "string",
        "default": "main"
      },
      "build_type": {
        "type": "string",
        "enum": ["Release", "Debug"],
        "default": "Release"
      },
      "bootstrap_deps": {
        "type": "boolean",
        "default": false
      },
      "enable_zeromq": {
        "type": "boolean",
        "default": false
      },
      "install_prefix": {
        "type": "string",
        "default": "/usr/local"
      },
      "dry_run": {
        "type": "boolean",
        "default": true
      }
    },
    "required": ["workspace"]
  },
  "outputSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "passed": { "type": "boolean" },
      "summary": { "type": "string" },
      "warnings": {
        "type": "array",
        "items": { "type": "string" }
      },
      "artifacts": {
        "type": "array",
        "items": { "type": "string" }
      },
      "next_steps": {
        "type": "array",
        "items": { "type": "string" }
      },
      "commands": {
        "type": "array",
        "items": { "type": "string" }
      },
      "source": { "type": "object" },
      "build_dir": { "type": "string" }
    },
    "required": [
      "passed",
      "summary",
      "warnings",
      "artifacts",
      "next_steps",
      "commands",
      "source",
      "build_dir"
    ]
  }
}
